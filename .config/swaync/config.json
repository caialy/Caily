{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "ignore-gtk-theme": true,
  "positionX": "right",
  "positionY": "top",
  "control-center-margin-top": 10,
  "control-center-margin-bottom": 10,
  "control-center-margin-right": 10,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "fit-to-screen": false,
  "control-center-width": 380,
  "control-center-height": 720,
  "notification-window-width": 340,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,
  "text-empty": "No Notification",
  "scripts": {
    "sound-script": {
      "exec": "paplay ~/.config/swaync/notification.ogg",
      "app-name": ".*"
    }
  },
  "widgets": [
    "title",
    "label#controls",
    "dnd",
    "menubar",
    "volume",
    "backlight",
    "mpris",
    "label#notifications",
    "notifications"
  ],
  "widget-config": {
    "notifications": {},
    "title": {
      "text": "Notification Center",
      "clear-all-button": true,
      "button-text": "󰆴 Clear All"
    },
    "label#controls": {
      "text": "Quick Controls",
      "max-lines": 1
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "menubar": {
      "menu#session": {
        "label": "󰍃 Session",
        "position": "left",
        "animation-type": "slide_down",
        "animation-duration": 200,
        "actions": [
          {
            "label": "󰌾  Lock",
            "command": "playerctl pause; $HOME/.config/sway/swaylock-corrupter.sh"
          },
          {
            "label": "󰍃  Log out",
            "command": "swaymsg exit"
          },
          {
            "label": "󰜉  Reboot",
            "command": "systemctl reboot"
          },
          {
            "label": "󰐥  Power off",
            "command": "systemctl poweroff"
          }
        ]
      },
      "buttons#quickactions": {
        "position": "right",
        "actions": [
          {
            "label": "󰕾",
            "command": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
          },
          {
            "label": "󰆴",
            "command": "swaync-client -C"
          }
        ]
      }
    },
    "volume": {
      "label": "󰕾"
    },
    "backlight": {
      "label": "󰃟"
    },
    "label#notifications": {
      "text": "Notifications",
      "max-lines": 1
    },
    "mpris": {
      "blacklist": [],
      "autohide": false,
      "show-album-art": "always",
      "loop-carousel": false,
      "image-size": 96,
      "image-radius": 12
    }
  }
}